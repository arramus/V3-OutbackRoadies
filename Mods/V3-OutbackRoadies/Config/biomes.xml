<configs>

	<set xpath="/worldgeneration/biomes/biome[@name='wasteland']/spectrum/@name">desert</set> <!-- Default is wasteland -->	
	<set xpath="/worldgeneration/biomes/biome[@name='wasteland']/weather[@name='default']/CloudThickness/@range">50,100</set>
	<set xpath="/worldgeneration/biomes/biome[@name='wasteland']/weather[@name='default']/Fog/@range">3,6</set>
	<set xpath="/worldgeneration/biomes/biome[@name='wasteland']/weather[@name='cold']/CloudThickness/@range">50,100</set>
	<set xpath="/worldgeneration/biomes/biome[@name='wasteland']/weather[@name='cold']/Fog/@range">3,6</set>
	<set xpath="/worldgeneration/biomes/biome[@name='wasteland']/weather[@name='hot']/CloudThickness/@range">50,100</set>
	<set xpath="/worldgeneration/biomes/biome[@name='wasteland']/weather[@name='hot']/Fog/@range">3,6</set>

	<!-- *** Pine Forest: Sub Biome: Clustered Flowers and Boulders -->
	<append xpath="/worldgeneration/biomes/biome[@name='pine_forest']/subbiome[@noise='.0095, 0, .21']/decorations">
			<decoration type="block" blockname="plantedBlueberry3Harvest" prob="0.05" rotatemax="7"/>
			<decoration type="block" blockname="plantedPotato3Harvest" prob="0.04" rotatemax="7"/>
			<decoration type="block" blockname="plantedHop3Harvest" prob="0.04" rotatemax="7"/>
			<decoration type="block" blockname="plantedPumpkin3Harvest" prob="0.04" rotatemax="7"/>
			<decoration type="block" blockname="plantedMushroom3Harvest" prob="0.04" rotatemax="7"/>	
	</append>
	
	<!-- *** Burnt Forest: Sub Biome: Mushrooms, Thick Grass, and Shrubs -->
	<append xpath="/worldgeneration/biomes/biome[@name='burnt_forest']/subbiome[@noise='.033, 0, .3']/decorations">
			<decoration type="block" blockname="plantedCoffee3Harvest" prob=".0025" rotatemax="7"/>
	</append>

	<!-- *** Desert: Sub Biome: Ring of Smaller Clustered Cactus and Desert Shrub -->
	<append xpath="/worldgeneration/biomes/biome[@name='desert']/subbiome[@noise='.02, 0, .45']/decorations">
			<decoration type="block" blockname="plantedCorn3Harvest" prob="0.0005" rotatemax="7"/>
			<decoration type="block" blockname="plantedGraceCorn3Harvest" prob="0.00025" rotatemax="7"/>
			<decoration type="block" blockname="treeStump" prob=".0002" rotatemax="7"/>
	</append>
	<!-- *** Desert: Sub Biome: Oil Shale -->
	<append xpath="/worldgeneration/biomes/biome[@name='desert']/subbiome[@noise='.04, 0, .3']/decorations">
			<decoration type="block" blockname="treeStump" prob=".00005" rotatemax="7"/>
	</append>	
	<!-- Decorations Main: Desert -->	
	<append xpath="/worldgeneration/biomes/biome[@name='desert']/decorations">
			<decoration type="block" blockname="treeStump" prob=".0001" rotatemax="7"/>		
	</append>

	<!-- Thickening the Wasteland tree density -->
	<set xpath="/worldgeneration/biomes/biome[@name='wasteland']/subbiome/decorations/decoration[@blockname='treeBurntMaple03']/@prob">.005</set>	
	<set xpath="/worldgeneration/biomes/biome[@name='wasteland']/subbiome/decorations/decoration[@blockname='treeBurntMaple04']/@prob">.0015</set>
	<set xpath="/worldgeneration/biomes/biome[@name='wasteland']/subbiome/decorations/decoration[@blockname='carWrecksRandomHelper']/@prob">.001</set>
	
	<!-- Wasteland: Decorations Main -->	
	<append xpath="/worldgeneration/biomes/biome[@name='wasteland']/decorations">
			<decoration type="block" blockname="emberPileDeco1" onslopes="false" prob=".0005" rotatemax="7"/>
			<decoration type="block" blockname="emberPileDeco2" onslopes="false" prob=".0005" rotatemax="7"/>			
			<decoration type="block" blockname="emberPileDeco3" onslopes="false" prob=".0025" rotatemax="7"/>
			<decoration type="block" blockname="emberPileDeco4" onslopes="false" prob=".0025" rotatemax="7"/>
	</append>

	<!-- ***** Street Parameters -->
	<append xpath="/worldgeneration/pois/poi[@name='City Asphalt']">
		<blockontop blockname="plantedCottonHarvestRandomHelper" prob="0.0025"/>
		<blockontop blockname="plantedtreeGrassSeedRandomHelper" prob="0.0035"/>
